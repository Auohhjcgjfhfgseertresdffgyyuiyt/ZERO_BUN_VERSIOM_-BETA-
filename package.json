    "#play": "./lib/api/play.js",
    "#spotify": "./lib/api/spotify.js",
    "#ytmp3": "./lib/api/ytmp3.js",
    "#ytmp4": "./lib/api/ytmp4.js",
    "#spotifydl": "./lib/api/spotifydl.js",
    "#removebg": "./lib/api/removebg.js",
    "#remini": "./lib/api/remini.js",
    "#global": "./src/global.js",
    "#settings": "./src/settings.js",
    "#sqlite-auth": "./lib/auth/sqlite-auth.js",
    "#loader-plugins": "./lib/core/loader-plugins.js",
    "#loader-plugins2": "./lib/core/loader-plugins2.js",
    "#cleaner": "./lib/core/cleaner.js",
    "#event": "./lib/core/event.js",
    "#chalk": "./modules/chalk.js",
    "#connection": "./lib/core/connection.js",
    "#logger": "./modules/logger.js",

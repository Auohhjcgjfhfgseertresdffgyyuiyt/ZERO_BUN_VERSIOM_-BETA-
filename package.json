    "node-webpmux": "^3.2.1",
    "sharp": "^0.34.4",
    "yt-search": "^2.13.1"
  },
  "devDependencies": {
    "ffmpeg-static": "^5.2.0",
    "node-webpmux": "^3.2.1",
    "prettier": "^3.6.2",
    "pino-pretty": "^13.1.2"
  },
  "imports": {
    "#tiktok": "./lib/api/tiktok.js",
    "#instagram": "./lib/api/instagram.js",
    "#twitter": "./lib/api/twitter.js",
